{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "moduleResolution": "bundler",
    "rootDir": "client",
    "outDir": "public",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["client/**/*.ts"]
}
